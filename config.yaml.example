# CVE Backporting Tool 配置文件示例
# 复制为 config.yaml 后按需修改

repositories:
  5.10-hulk:
    path: /path/to/linux
    branch: linux-5.10.y

cache:
  enabled: true
  database_path: ./commit_cache.db
  max_cached_commits: 10000000

# 内核版本间的路径迁移映射
# upstream: 社区高版本路径前缀
# local:    本地低版本路径前缀
# since:    从哪个版本开始发生了迁移 (仅供参考)
#
# 工具会自动双向翻译：
#   社区补丁中的 fs/smb/client/foo.c → 在本地搜索 fs/cifs/foo.c
#   本地 commit 中的 fs/cifs/foo.c → 比较时等价于 fs/smb/client/foo.c
path_mappings:
  # ── 6.2: CIFS/SMB 子系统重组 ──
  - upstream: fs/smb/client/
    local: fs/cifs/
    since: "6.2"
  - upstream: fs/smb/server/
    local: fs/ksmbd/
    since: "6.2"
  - upstream: fs/smb/common/
    local: fs/smbfs_common/
    since: "6.2"

  # ── 6.2: DRM AMD display link 重构 ──
  - upstream: drivers/gpu/drm/amd/display/dc/link/
    local: drivers/gpu/drm/amd/display/dc/core/
    since: "6.2"

  # ── 5.18: i915 display 拆分 ──
  - upstream: drivers/gpu/drm/i915/display/
    local: drivers/gpu/drm/i915/
    since: "5.18"

  # ── 5.16: rtw89 从 staging 毕业 ──
  - upstream: drivers/net/wireless/realtek/rtw89/
    local: drivers/staging/rtw89/
    since: "5.16"

  # ── 6.5: ath12k 从 staging 毕业 ──
  - upstream: drivers/net/wireless/ath/ath12k/
    local: drivers/staging/ath12k/
    since: "6.5"

  # ── 6.1: fscache → netfs 重组 ──
  - upstream: fs/netfs/
    local: fs/fscache/
    since: "6.1"

  # ── 自定义映射 (按需添加) ──
  # - upstream: path/in/newer/kernel/
  #   local: path/in/your/kernel/
  #   since: "x.y"
